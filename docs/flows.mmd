flowchart TD
  Start["Inicio: cliente o asistente inicia la solicitud"] --> Entry{"Canal de entrada"}
  Entry -->|HTTP API| Capture["Recibir datos personales + oferta + beneficios"]
  Entry -->|CLI / asistente| Capture

  Capture --> Create["Crear propuesta"]
  Create --> Received["Estado inicial: status = RECEIVED\ncardCreationStatus = NOT_CREATED"]
  Received --> EventReceived["Persistir propuesta + auditoria\nPublicar outbox: proposal.received"]

  EventReceived --> OfferValidation["Validar elegibilidad de oferta"]
  OfferValidation --> OfferRules["Evaluar reglas:\nA: income > 1000\nB: income > 15000 and investments > 5000\nC: income > 50000 and currentAccountYears > 2"]
  OfferRules --> OfferDecision{"Oferta seleccionada elegible?"}
  OfferDecision -->|Si| OfferApproved["Actualizar status = OFFER_VALIDATED\nAuditoria: offer.validated\nOutbox: offer.eligibility.calculated"]
  OfferDecision -->|No| Rejected["Final de negocio: status = REJECTED\nRegistrar motivo y auditoria"]

  OfferApproved --> BenefitsValidation["Validar beneficios seleccionados"]
  BenefitsValidation --> BenefitsRules["Reglas:\nCASHBACK y POINTS no coexistentes\nTRAVEL_INSURANCE solo oferta C\nVIP_LOUNGE solo ofertas B y C\nBeneficios desconocidos se rechazan"]
  BenefitsRules --> BenefitsDecision{"Seleccion valida?"}
  BenefitsDecision -->|Si| BenefitsApproved["Actualizar status = BENEFITS_VALIDATED\nAuditoria: benefits.validated\nOutbox: benefits.selection.validated"]
  BenefitsDecision -->|No| Rejected

  BenefitsApproved --> Submit["Enviar propuesta"]
  Submit --> Submitted["Actualizar status = SUBMITTED\nAuditoria: proposal.submitted\nOutbox: proposal.submitted"]

  Submitted --> CardRequest["Solicitar creacion de cuenta de tarjeta"]
  CardRequest --> Requested["Actualizar cardCreationStatus = REQUESTED\nAuditoria: card.creation.requested\nOutbox: card.creation.requested"]
  Requested --> CardProvider{"Adapter de tarjeta responde"}
  CardProvider -->|Exito| CardCreated["Actualizar status = CARD_ACCOUNT_CREATED\ncardCreationStatus = CREATED\nGuardar cardId\nAuditoria: card.created\nOutbox: card.created"]
  CardProvider -->|Falla tecnica| CardFailed["Estado operativo: cardCreationStatus = FAILED\nstatus principal permanece SUBMITTED\nAuditoria: card.creation.failed\nOutbox: card.creation.failed"]

  CardFailed --> RetryDecision{"Se reintenta crear tarjeta?"}
  RetryDecision -->|Si| CardRequest
  RetryDecision -->|No| PendingEnd["Fin operativo incompleto:\npropuesta sigue SUBMITTED con cardCreationStatus = FAILED"]

  CardCreated --> Activation["Activar beneficios seleccionados"]
  Activation --> ActivationLoop["Ejecutar activacion por beneficio\nActualizar benefitActivationStatus"]
  ActivationLoop --> ActivationDecision{"Todos activados?"}
  ActivationDecision -->|Si| Completed["Fin exitoso: status = COMPLETED\nAuditoria: proposal.completed\nOutbox: benefits.activated"]
  ActivationDecision -->|No| PartialEnd["Fin operativo parcial:\nstatus no llega a COMPLETED\nOutbox: benefits.activated"]

  Rejected --> StatusQuery["Cliente consulta estado"]
  PendingEnd --> StatusQuery
  PartialEnd --> StatusQuery
  Completed --> StatusQuery

  StatusQuery --> StatusPayload["Respuesta actual de status:\nproposalId\nstatus\ncardCreationStatus\nselectedBenefits\nrejectionReason\ncardId"]
  StatusPayload --> GapNote["Gap actual:\nla consulta de status no incluye benefitActivationStatus"]

  AssistantAI["Asistente IA con OpenAI o fallback local"] --> Capture
  AssistantAI --> StatusQuery

  SensitiveData["Dato sensible presente en el flujo:\nfullName, nationalId, email, income, investments"] -.-> Capture
  SensitiveData -.-> EventReceived
  SensitiveData -.-> StatusPayload

  subgraph Finales["Finales del flujo actual"]
    Rejected
    PendingEnd
    PartialEnd
    Completed
  end
